{
  "framework": "nextjs",
  "buildCommand": "next build",
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 6 */2 * *"
    }
  ],
  "functions": {
    "api/cron/scrape.js": {
      "maxDuration": 300
    },
    "api/scrape-events.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/clubs-data.json",
      "destination": "/404.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "evrouteplanner.org"
        }
      ],
      "destination": "/ev-route-planner.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.evrouteplanner.org"
        }
      ],
      "destination": "/ev-route-planner.html",
      "permanent": false
    },
    {
      "source": "/paddle-events-admin.html",
      "destination": "/admin/events",
      "permanent": true
    },
    {
      "source": "/paddle-clubs-admin.html",
      "destination": "/admin/clubs",
      "permanent": true
    },
    {
      "source": "/paddle-gear-admin.html",
      "destination": "/admin/gear",
      "permanent": true
    },
    {
      "source": "/updates-admin.html",
      "destination": "/admin/feedback",
      "permanent": true
    },
    {
      "source": "/pp-admin.html",
      "destination": "/admin",
      "permanent": true
    }
  ]
}
