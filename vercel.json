{
  "rewrites": [
    {
      "source": "/clubs-data.json",
      "destination": "/404.html"
    }
  ],
  "headers": [
    {
      "source": "/api/clubs",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)\\.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=86400" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "evrouteplanner.org" }],
      "destination": "/ev-route-planner.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.evrouteplanner.org" }],
      "destination": "/ev-route-planner.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "paddlepoint.org" }],
      "destination": "/paddlepoint.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.paddlepoint.org" }],
      "destination": "/paddlepoint.html",
      "permanent": false
    }
  ]
}
